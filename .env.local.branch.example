# Copy to .env.local.branch, fill in the secret key, then: npm run env:branch
#
# Keys: Project Settings (gear) → API Keys (NOT Integrations → Data API)
# https://supabase.com/dashboard/project/iyuwxdjauhlaeejstlde/settings/api-keys
#
# NEXT_PUBLIC_SUPABASE_ANON_KEY  = Publishable key (sb_publishable_...)
# SUPABASE_SERVICE_ROLE_KEY = Secret (sb_secret_...) OR legacy service_role JWT
# sb_secret works for DB; Edge invokes use legacy anon JWT from preview-branch.json automatically

NEXT_PUBLIC_SUPABASE_URL=https://iyuwxdjauhlaeejstlde.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_preview_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_preview_secret_or_service_role_key

# Branch-only experiment: topic-explorer home + shell (docs/UI Layout.png).
# Off by default; only set on the preview branch. Restart dev after changing.
NEXT_PUBLIC_EXPERIMENT_HOME_UI=true
